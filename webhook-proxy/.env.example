# Port the proxy listens on inside the container
PORT=3001

# Internal URL of the OpenClaw gateway (Docker network)
OPENCLAW_INTERNAL_URL=http://openclaw-gateway:18789

# OpenClaw hooks token (set in hooks.token in openclaw.json)
OPENCLAW_HOOKS_TOKEN=your-openclaw-hooks-token-here

# GitHub App webhook secret (set when creating the GitHub App)
WEBHOOK_SECRET_GITHUB=your-github-webhook-secret-here

# Future providers — add as needed:
# WEBHOOK_SECRET_STRIPE=
# WEBHOOK_SECRET_LINEAR=
