# OpenClaw — Coolify environment variables
# Copy to .env and fill in your values (or set them in Coolify UI).

# ─── Required ────────────────────────────────────────────────────
# Auth token for the Control UI + API.
# Generate one with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me

# ─── Recommended ─────────────────────────────────────────────────
# Your public domain (e.g. openclaw.example.com).
# Used to set gateway.controlUi.allowedOrigins on first boot.
# If unset, the gateway falls back to Host-header origin mode.
OPENCLAW_DOMAIN=

# ─── Optional: Ports ─────────────────────────────────────────────
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# ─── Optional: Network ──────────────────────────────────────────
# Allow trusted private-network ws:// targets (default: loopback only)
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# ─── Optional: Claude / Anthropic session keys ──────────────────
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
